# Copy this file to secrets.toml in this same directory and fill in your keys.
# .streamlit/secrets.toml is gitignored — never commit your real keys.

# Required for AI features (free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY = ""

# Optional fallback data source
# Get free key at https://finnhub.io
# yfinance is the primary source (no key needed) — Finnhub is only used as fallback
FINNHUB_API_KEY = ""

# Optional: override default Gemini model
# GEMINI_MODEL = "gemini-2.5-flash"
